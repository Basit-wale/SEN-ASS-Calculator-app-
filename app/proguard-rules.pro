# Add project specific ProGuard rules here.
# By default, the flags in this file are appended to flags specified in
# the Android SDK tools. You can edit the include path and order by changing
# the proguardFiles directive in build.gradle.

# Keep line number info for crash/exception stack traces
-keepattributes SourceFile,LineNumberTable

# If you keep the line number information, uncomment this to hide the original
# source file name:
# -renamesourcefileattribute SourceFile